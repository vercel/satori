{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "lib": ["ESNext", "DOM"],
    "isolatedDeclarations": true
  },
  "include": ["src", "vendor/*.d.ts"],
  "exclude": ["dist", "node_modules"]
}
